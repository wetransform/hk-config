// https://trivy.dev/docs/latest/scanner/secret/
// renovate: datasource=github-tags depName=aquasecurity/trivy
local trivy_version = "0.69.3"

trivysecrets = new Config.Step {
  // Note: trivy fs can only take one file/path as argument, so we can only scan the current directory and not pass the files
  check = "trivy fs --exit-code 1 --scanners secret ."
  prefix = "mise x trivy@\(trivy_version) --"
  tests {
    ["clean directory passes"] {
      run = "check"
      tmpdir = true
      write {
        ["clean.txt"] = "just some normal text\n"
      }
      expect { code = 0 }
    }
    ["detects secret in directory"] {
      run = "check"
      tmpdir = true
      write {
        // Note: AKIAIOSFODNN7EXAMPLE is on trivy's allowlist as a well-known example, so we use a slightly different key
        ["secret.env"] = "AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPZZ\n"
      }
      expect { code = 1 }
    }
  }
}

// https://docs.renovatebot.com/config-validation/
// renovate: datasource=npm depName=renovate
local renovate_version = "43.100.0"

renovate = new Config.Step {
  glob =
    List(
      "renovate.json",
      "renovate.json5",
      ".github/renovate.json",
      ".github/renovate.json5",
      ".gitlab/renovate.json",
      ".gitlab/renovate.json5",
      ".renovaterc",
      ".renovaterc.json",
      ".renovaterc.json5",
    )
  // Note: strict flag enables failing for migration warnings as well
  // specifying no file path runs for default config file paths (only one file is expected to be present)
  check = "renovate-config-validator --strict"
  prefix = "mise exec npm:renovate@\(renovate_version) -- "
}

// Validate YAML files against JSON schemas specified in comments at the top of the file,
// using the `check-jsonschema` tool from pipx (which supports both local and remote schemas).
//
// Supported comment formats (within the first 5 lines of the file):
//   # yaml-language-server: $schema=path/to/schema.json
//   # yaml-language-server: $schema=http://example.com/schema.json
//   # $schema: path/to/schema.json
//   # $schema: http://example.com/schema.json
//
// The notations with "$schema:" is preferred as it is supported by both IntelliJ and YAML Language Server
// (used for example by VS Code's YAML extension), while the "yaml-language-server: $schema=" format is only
// supported by the YAML Language Server.
//
// renovate: datasource=pypi depName=check-jsonschema
local check_jsonschema_version = "0.37.1"

yaml_schema = new Config.Step {
  glob = List("**/*.yaml", "**/*.yml")
  shell = "mise x pipx:check-jsonschema@\(check_jsonschema_version) -- bash -o errexit -c"
  check =
    #"""
    failed=0
    for f in {{files}}; do
        # Extract schema from the first 5 lines of the file
        schema=$(head -5 "$f" | tr -d '\r' | sed -n \
            -e 's/^#[[:space:]]*yaml-language-server:[[:space:]]*\$schema=\(.*\)/\1/p' \
            -e 's/^#[[:space:]]*\$schema:[[:space:]]*\(.*\)/\1/p' \
        | head -1 | sed 's/[[:space:]]*$//')

        if [ -z "$schema" ]; then
            # No schema comment found — skip this file silently
            continue
        fi

        # Resolve relative paths relative to the YAML file's directory
        case "$schema" in
            http://*|https://*) ;;
            *) schema="$(dirname "$f")/$schema" ;;
        esac

        echo "Validating $f against $schema"
        if ! check-jsonschema --schemafile "$schema" "$f"; then
            failed=1
        fi
    done
    exit $failed
    """#
  tests {
    ["skips file without schema comment"] {
      run = "check"
      tmpdir = true
      write {
        ["no-schema.yaml"] = "key: value\n"
      }
      expect { code = 0 }
    }
    ["passes valid YAML with $schema comment"] {
      run = "check"
      tmpdir = true
      write {
        ["schema.json"] =
          #"{"type":"object","required":["name"],"properties":{"name":{"type":"string"}}}"#
        ["valid.yaml"] = "# $schema: schema.json\nname: hello\n"
      }
      expect { code = 0; stdout = "Validating" }
    }
    ["passes valid YAML with yaml-language-server comment"] {
      run = "check"
      tmpdir = true
      write {
        ["schema.json"] =
          #"{"type":"object","required":["name"],"properties":{"name":{"type":"string"}}}"#
        ["valid.yaml"] = "# yaml-language-server: $schema=schema.json\nname: hello\n"
      }
      expect { code = 0; stdout = "Validating" }
    }
    ["fails invalid YAML against schema"] {
      run = "check"
      tmpdir = true
      write {
        ["schema.json"] =
          #"{"type":"object","required":["name"],"properties":{"name":{"type":"string"}}}"#
        ["invalid.yaml"] = "# $schema: schema.json\nother: value\n"
      }
      expect { code = 1 }
    }
  }
}
